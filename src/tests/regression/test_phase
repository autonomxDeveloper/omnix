# ---------------------------------------------------------------------------
# GM hooks regression
# ---------------------------------------------------------------------------

class TestGMHooksRegression:
    def test_force_npc_goal_preserves_state(self, base_sim_state):
        out = gm_force_npc_goal(base_sim_state, "npc1", {"goal_id": "g1"})
        assert len(out["npc_minds"]["npc1"]["goals"]) == 1

    def test_force_faction_trend_adds_sandbox(self, base_sim_state):
        out = gm_force_faction_trend(base_sim_state, "faction1", {"aggression": 0.3})
        assert out["sandbox_state"]["faction_trends"]["faction1"]["aggression"] == 0.3

    def test_debug_note_bounded(self, base_sim_state):
        state = base_sim_state
        for i in range(60):
            state = gm_append_debug_note(state, f"note-{i}")
        assert len(state["debug_meta"]["gm_notes"]) == 50



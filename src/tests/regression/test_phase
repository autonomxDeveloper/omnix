# ---------------------------------------------------------------------------
# Tick diff regression
# ---------------------------------------------------------------------------

class TestTickDiffRegression:
    def test_build_tick_diff_safe_with_none(self):
        """build_tick_diff should gracefully handle None inputs."""
        diff = build_tick_diff(None, None)
        assert diff["tick_before"] == 0
        assert diff["tick_after"] == 0
        assert diff["new_events"] == []

    def test_build_tick_diff_with_extra_keys(self):
        """Extra top-level keys in state should not blow up the diff."""
        before = {"tick": 1, "events": [], "consequences": [], "social_state": {}, "sandbox_state": {}, "npc_minds": {}}
        after = dict(before, foo="bar", tick=2)
        diff = build_tick_diff(before, after)
        assert diff["tick_before"] == 1
        assert diff["tick_after"] == 2


# ---------------------------------------------------------------------------
# Timeline regression
# ---------------------------------------------------------------------------

class TestTimelineRegression:
    def test_build_timeline_summary_empty(self, base_sim_state):
        summary = build_timeline_summary(base_sim_state)
        assert summary["current_tick"] == 1
        assert summary["snapshot_count"] == 0

    def test_build_timeline_summary_with_snapshots(self, base_sim_state):
        base_sim_state["snapshots"] = [
            {"tick": 0, "snapshot_id": "s0", "label": "start"},
            {"tick": 1, "snapshot_id": "s1", "label": "step1"},
        ]
        summary = build_timeline_summary(base_sim_state)
        assert summary["snapshot_count"] == 2

    def test_get_timeline_tick_missing(self, base_sim_state):
        result = get_timeline_tick(base_sim_state, 99)
        assert result["snapshot"] == {}

    def test_safety_with_corrupt_state(self):
        summary = build_timeline_summary("not-a-dict")
        assert summary["snapshot_count"] == 0



class TestEncounterEnd:
    def test_end_returns_ok(self, client):
        scene = {"scene_id": "s1", "scene_type": "combat", "actors": [{"id": "player"}]}
        first = client.post("/api/rpg/encounter/start", json={"setup_payload": {}, "scene": scene}).get_json()
        resp = client.post("/api/rpg/encounter/end", json={"setup_payload": first["setup_payload"]})
        data = resp.get_json()
        assert data["encounter_state"]["status"] == "aborted"
+    world_seed = _safe_dict(preview.get("world_seed"))
+    visual_defaults = _safe_dict(preview.get("visual_defaults"))
+    characters = _safe_list(preview.get("characters"))
+
+    setup = {
+        "title": _first_non_empty(

+-Behavior of resolve_selected_option(option_id)
+-get current/last choice set from GameplayControlController
+-find option by option_id
+-resolve with ActionResolver
+-emit resulting events into EventBus
+-apply coherence updates on those action events immediately or on next tick depending on your loop policy
+-Recommended approach
+-
+-For 7.3, keep it simple and explicit:
+-
+-resolve_selected_option(...) should:
+-resolve
+-emit events
+-apply coherence immediately for those action events
+-return the action resolution result
+-
+-That gives you a usable interaction path outside the normal tick loop.
+-
+-Example implementation shape
+-def resolve_selected_option(self, option_id: str) -> dict:
+-    option = self.gameplay_control_controller.select_option(option_id)
+-    if option is None:
+-        return {"ok": False, "reason": "unknown_option", "option_id": option_id}
+-
+-    result = self.action_resolver.resolve_choice(
+-        option=option,
+-        coherence_core=self.coherence_core,
+-        gm_state=self.gm_directive_state,
+-    )
+-
+-    self._emit_action_resolution_events(result.to_dict())
+-    self._apply_coherence_updates_from_action_result(result.to_dict())
+-
+-    return {
+-        "ok": True,
+-        "resolution": result.to_dict(),
+-        "scene_summary": self.coherence_core.get_scene_summary(),
+-    }
+-Add helper
+-_apply_coherence_updates_from_action_result(self, result: dict) -> dict
+-
+-This should extract events and apply them via CoherenceCore.
+-
+-Important rule
+-
+-Do not directly mutate coherence from the option itself. Always go through emitted events.

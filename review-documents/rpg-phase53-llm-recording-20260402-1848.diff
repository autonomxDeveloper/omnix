+        from app.rpg.core.event_bus import Event
+
+        events = [Event(type="combat", payload={"actor": "guard"})]
+        context = {"npc": "guard", "goal": "attack"}
+
+        live_eval = evaluator_live.evaluate_detailed(events, context)
+
+        # Replay mode

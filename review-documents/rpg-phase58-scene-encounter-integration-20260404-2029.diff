### NEW FILE — `src/app/rpg/creator/world_scene_generator.py`

```python
"""Phase 58 — Scene / Encounter Generator"""

from __future__ import annotations
from typing import Any

SCENE_TYPE_CONFLICT = "conflict"
SCENE_TYPE_ENCOUNTER = "encounter"
SCENE_TYPE_POLITICAL = "political"
SCENE_TYPE_INVESTIGATION = "investigation"
SCENE_TYPE_NEGOTIATION = "negotiation"

VALID_SCENE_TYPES = frozenset({
    SCENE_TYPE_CONFLICT, SCENE_TYPE_ENCOUNTER, SCENE_TYPE_POLITICAL,
    SCENE_TYPE_INVESTIGATION, SCENE_TYPE_NEGOTIATION,
})

_MAX_SCENES = 20

def _safe_list(v):
    return v if isinstance(v, list) else []

def _safe_str(v, default=""):
    return str(v) if v is not None else default

def _build_scene_id(source_id, suffix):
    return f"scene_{source_id}_{suffix}"

def _map_thread_crisis(inc):
    source = _safe_str(inc.get("source_id"), "unknown")
    pressure = inc.get("pressure", 0)
    stakes = "Critical escalation imminent" if pressure >= 5 else "High tension conflict" if pressure >= 3 else "Moderate conflict"
    return {
        "scene_id": _build_scene_id(source, "crisis"),
        "type": SCENE_TYPE_CONFLICT,
        "title": f"Crisis Escalation: {source}",
        "summary": _safe_str(inc.get("summary"), "A crisis has escalated."),
        "actors": [source], "stakes": stakes,
        "severity": inc.get("severity", "neutral"),
        "source_incident_id": inc.get("id"),
    }

def generate_scenes_from_incidents(incidents, *, max_scenes=_MAX_SCENES):
    scenes = []
    for inc in _safe_list(incidents):
        inc_type = _safe_str(inc.get("type"))
        if inc_type == "thread_crisis":
            scenes.append(_map_thread_crisis(inc))
    return scenes[:max_scenes]

def generate_scenes_from_simulation(state, *, max_scenes=_MAX_SCENES):
    incidents = _safe_list(state.get("incidents"))
    if not incidents:
        sim_state = state.get("simulation_state")
        if isinstance(sim_state, dict):
            incidents = _safe_list(sim_state.get("incidents"))
    return generate_scenes_from_incidents(incidents, max_scenes=max_scenes)
```


+"""Phase 4.5 — Player Action → Simulation Feedback.
+
+Provides deterministic action → consequence mapping and state mutation
+so that player input can directly influence the adventure builder's
+simulation state.
+
+The gameplay loop enabled by this module is:
+
+    Scene → Player Action → Simulation Mutation → New World State → New Scenes
+
+All mutations are fully deterministic and idempotent given the same
+(state, action) pair.
+"""
+
+from __future__ import annotations
+
+from typing import Any
+
+
+# Valid action types
+INTERVENE_THREAD = "intervene_thread"
+SUPPORT_FACTION = "support_faction"
+ESCALATE_CONFLICT = "escalate_conflict"
+
+VALID_ACTION_TYPES = {
+    INTERVENE_THREAD,
+    SUPPORT_FACTION,
+    ESCALATE_CONFLICT,
+}
+
+
+def apply_player_action(
+    state: dict[str, Any],
+    action: dict[str, Any],
+) -> dict[str, Any]:
+    """Mutate simulation state based on a player action."""
+    import copy
+
+    state = copy.deepcopy(state)
+
+    action_type = action.get("type", "")
+    target_id = action.get("target_id") or action.get("target")
+
+    threads = _safe_dict(state.get("threads"))
+    factions = _safe_dict(state.get("factions"))
+    locations = _safe_dict(state.get("locations"))
+    events = _safe_list(state.get("events"))
+    consequences = _safe_list(state.get("consequences"))
+
+    action_applied = False
+
+    # --- Rule: intervene_thread reduces thread pressure by 2 ---
+    if action_type == INTERVENE_THREAD and target_id in threads:
+        old_pressure = threads[target_id].get("pressure", 0)
+        threads[target_id]["pressure"] = _cap(old_pressure - 2)
+        threads[target_id]["status"] = _thread_status(threads[target_id]["pressure"])
+        action_applied = True
+
+        events.append({
+            "type": "player_intervention",
+            "target_id": target_id,
+            "summary": f"Player intervened in thread '{target_id}' (pressure {old_pressure} → {threads[target_id]['pressure']})",
+            "severity": "positive",
+        })
+        consequences.append({
+            "type": "pressure_reduction",
+            "target_id": target_id,
+            "summary": f"Pressure on '{target_id}' reduced",
+        })
+
+    # --- Rule: support_faction reduces faction pressure by 1 ---
+    if action_type == SUPPORT_FACTION and target_id in factions:
+        old_pressure = factions[target_id].get("pressure", 0)
+        factions[target_id]["pressure"] = _cap(old_pressure - 1)
+        factions[target_id]["status"] = _faction_status(factions[target_id]["pressure"])
+        action_applied = True
+
+        events.append({
+            "type": "player_support",
+            "target_id": target_id,
+            "summary": f"Player supported faction '{target_id}' (pressure {old_pressure} → {factions[target_id]['pressure']})",
+            "severity": "positive",
+        })
+        consequences.append({
+            "type": "faction_stabilized",
+            "target_id": target_id,
+            "summary": f"Faction '{target_id}' stabilized",
+        })
+
+    # --- Rule: escalate_conflict increases thread pressure by 2 and nearby faction pressure by 1 ---
+    if action_type == ESCALATE_CONFLICT and target_id in threads:
+        old_pressure = threads[target_id].get("pressure", 0)
+        threads[target_id]["pressure"] = _cap(old_pressure + 2)
+        threads[target_id]["status"] = _thread_status(threads[target_id]["pressure"])
+        action_applied = True
+
+        events.append({
+            "type": "player_escalation",
+            "target_id": target_id,
+            "summary": f"Player escalated conflict in thread '{target_id}' (pressure {old_pressure} → {threads[target_id]['pressure']})",
+            "severity": "negative",
+        })
+        consequences.append({
+            "type": "pressure_increase",
+            "target_id": target_id,
+            "summary": f"Pressure on '{target_id}' increased",
+        })
+
+        # Also push connected factions slightly
+        for fid, fstate in factions.items():
+            old_fp = fstate.get("pressure", 0)
+            factions[fid]["pressure"] = _cap(old_fp + 1)
+            factions[fid]["status"] = _faction_status(factions[fid]["pressure"])
+
+    # --- Fallback: unknown action type ---
+    if not action_applied and action_type:
+        events.append({
+            "type": "unknown_action",
+            "target_id": target_id,
+            "summary": f"Unhandled action type: {action_type}",
+            "severity": "neutral",
+        })
+
+    state["threads"] = threads
+    state["factions"] = factions
+    state["locations"] = locations
+    state["events"] = events
+    state["consequences"] = consequences
+
+    return state



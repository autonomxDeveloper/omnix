+    if (!node) return;
+
+    selectedCharacterId = String(node.getAttribute("data-character-id") || "");
+    const selected = characters.find((c) => String(c?.id || "") === selectedCharacterId) || null;
+
+    renderCharacterList(inspectorState);
+    renderCharacterInspector(selected);
+  };
+}

++def _keys_changed(before: Dict[str, Any], after: Dict[str, Any]) -> List[str]:
++    all_keys = sorted(set(before.keys()) | set(after.keys()))
++    changed = []
++    for key in all_keys:
++        if before.get(key) != after.get(key):
++            changed.append(str(key))
++    return changed

+        # If the scene is wrapped in a 'narrative' key (e.g., by renderer),
+        # extract the actual payload from there
+        narrative_wrapper = scene.get("narrative")
+        payload = narrative_wrapper if isinstance(narrative_wrapper, dict) else scene
+
+        # Extract body text from multiple possible locations
+        body = (
+            payload.get("body")
+            or payload.get("scene")
+            or payload.get("text")
+            or payload.get("description")
+            or scene.get("body")
+            or scene.get("scene")
+            or scene.get("text")
+            or ""
+        )
+
+        # Extract meta from multiple locations and merge
+        payload_meta = payload.get("meta", {}) or {}
+        payload_metadata = payload.get("metadata", {}) or {}
+        scene_meta = scene.get("meta", {}) or {}
+        scene_metadata = scene.get("metadata", {}) or {}
+
+        # Recovery metadata propagation
+        meta = {**payload_meta, **scene_meta}
+        metadata = {**payload_metadata, **scene_metadata}
+
+        # If payload has recovery flags, ensure they're at root too
+        if payload_meta.get("recovered") and not meta.get("recovered"):
+            meta["recovered"] = payload_meta["recovered"]
+        if payload_metadata.get("recovery") and not metadata.get("recovery"):
+            metadata["recovery"] = payload_metadata["recovery"]
+        if payload_meta.get("recovery_reason") and not meta.get("recovery_reason"):
+            meta["recovery_reason"] = payload_meta["recovery_reason"]
+        if payload_meta.get("recovery_policy") and not meta.get("recovery_policy"):
+            meta["recovery_policy"] = payload_meta["recovery_policy"]
+
+        # Extract options
+        options = payload.get("options", []) or scene.get("options", []) or []
+
+        normalized = {
+            "scene": body,
+            "body": body,
+            "options": options,
+            "meta": meta,
+            "metadata": metadata,
+        }
+
+        # Preserve other keys from both payload and scene
+        for key in ("title", "summary", "status", "prompt", "scene_data"):
+            if key in payload and key not in normalized:
+                normalized[key] = payload[key]
+            elif key in scene and key not in normalized:
+                normalized[key] = scene[key]
+
+        # Keep narrative key if present
+        if "narrative" in scene:
+            normalized["narrative"] = scene["narrative"]
+
+        return normalized

